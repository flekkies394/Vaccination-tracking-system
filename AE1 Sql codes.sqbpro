(88, 14, 22, 9, 5, NULL, '2024-06-05', '13:30:00', 3, 'Right arm', NULL, NULL);</sql><sql name="SQL 3">--Query using JOIN accross 3+ table
--Vaccination Inventory status per Clinic
SELECT 
    c.clinic_name,
    v.vaccine_name,
    vb.batch_number,
    vb.quantity_received,
    vb.quantity_remaining,
    vb.expiry_date
FROM VaccineBatch vb
JOIN Vaccine v ON vb.vaccine_id = v.vaccine_id
JOIN Clinic c ON vb.clinic_id = c.clinic_id
ORDER BY c.clinic_name, vb.expiry_date;


--Query 2: Full vaccination record per Patient
SELECT 
	p.first_name,
	p.last_name,
	v.vaccine_name,
	c.clinic_name, 
	hw.first_name,
	hw.last_name,
	vr.administered_date,
	vr.dose_number
FROM VaccinationRecord vr
JOIN Patient p ON vr . patient_id = p. patient_id
JOIN vaccine v ON vr. Vaccine_id = v.vaccine_id
JOIN Clinic c ON vr.clinic_id = c.clinic_id
JOIN HealthcareWorker hw ON vr.worker_id = hw.worker_id
ORDER BY p.last_name, vr.administered_date;


--Query using Subqueries
--Subquery 1: patients with no VaccinationRecord
SELECT 
	p.patient_id,
	p.first_name,
	p.last_name,
	p.neighbourhood,
	p.insurance_status,
	c.clinic_name
FROM Patient p
LEFT JOIN Clinic c ON c.clinic_id = p.primary_clinic_id
WHERE p.patient_id NOT IN (SELECT DISTINCT patient_id FROM VaccinationRecord)
ORDER BY p.neighbourhood, p.last_name;


-- Subquery 2: workers above average vaccination count
SELECT 
    hw.first_name,
    hw.last_name,
    COUNT(vr.record_id) AS vaccinations_given
FROM HealthcareWorker hw
JOIN VaccinationRecord vr ON vr.worker_id = hw.worker_id
GROUP BY hw.worker_id
HAVING COUNT(vr.record_id) &gt; (
    SELECT AVG(cnt) FROM (
        SELECT COUNT(*) AS cnt FROM VaccinationRecord GROUP BY worker_id
    )
)
ORDER BY vaccinations_given DESC;


-- GROUP BY + HAVING: Clinics with fewer than 10 vaccinations administered
SELECT c.clinic_name, c.neighbourhood, COUNT(vr.record_id) AS total
FROM Clinic c
LEFT JOIN VaccinationRecord vr ON vr.clinic_id = c.clinic_id
GROUP BY c.clinic_id, c.clinic_name, c.neighbourhood
HAVING COUNT(vr.record_id) &lt; 10
ORDER BY total;


-- GROUP BY + HAVING: Most administered vaccines per Clinic
SELECT c.clinic_name, v.vaccine_name, v.manufacturer,
       COUNT(vr.record_id) AS administered
FROM VaccinationRecord vr
JOIN Vaccine v ON v.vaccine_id = vr.vaccine_id
JOIN Clinic  c ON c.clinic_id  = vr.clinic_id
GROUP BY c.clinic_id, v.vaccine_id
HAVING COUNT(vr.record_id) &gt; 5
ORDER BY administered DESC;


--sustainability(SDG 3): Vaccination Coverage rate per neighbourhood
SELECT p.neighbourhood,
       COUNT(DISTINCT p.patient_id)  AS registered,
       COUNT(DISTINCT vr.patient_id) AS vaccinated,
       ROUND(CAST(COUNT(DISTINCT vr.patient_id) AS REAL)
             /COUNT(DISTINCT p.patient_id)*100,1) AS coverage_pct,
       SUM(CASE WHEN p.insurance_status='Uninsured' THEN 1 ELSE 0 END) AS uninsured
FROM Patient p
LEFT JOIN VaccinationRecord vr ON vr.patient_id = p.patient_id
GROUP BY p.neighbourhood ORDER BY  coverage_pct DESC;


--Sustainability (SDG-3): Adverse Reaction Monitoring
SELECT c.clinic_name, v.vaccine_name, COUNT(vr.record_id) AS doses,
       SUM(CASE WHEN vr.adverse_reaction IS NOT NULL THEN 1 ELSE 0 END) AS events,
       ROUND(CAST(SUM(CASE WHEN vr.adverse_reaction IS NOT NULL THEN 1 ELSE 0 END) AS REAL)
             /COUNT(vr.record_id)*100,2) AS event_rate_pct
FROM VaccinationRecord vr
JOIN Vaccine v ON v.vaccine_id = vr.vaccine_id
JOIN Clinic  c ON c.clinic_id  = vr.clinic_id
GROUP BY c.clinic_id, v.vaccine_id
HAVING COUNT(vr.record_id) &gt;= 2 AND events &gt; 0
ORDER BY event_rate_pct DESC;

--Indexes
CREATE INDEX idx_vaccinationrecord_clinic ON VaccinationRecord(clinic_id);
CREATE INDEX idx_vaccinationrecord_patient ON VaccinationRecord(patient_id);
CREATE INDEX idx_vaccinationrecord_vaccine ON VaccinationRecord(vaccine_id);
CREATE INDEX idx_vaccinationrecord_worker ON VaccinationRecord(worker_id);
CREATE INDEX idx_vaccinebatch_clinic ON VaccineBatch(clinic_id);
CREATE INDEX idx_vaccinebatch_vaccine ON VaccineBatch(vaccine_id);
CREATE INDEX idx_patient_neighbourhood ON Patient(neighbourhood);
CREATE INDEX idx_patient_primaryclinic ON Patient(primary_clinic_id);</sql><current_tab id="0"/></tab_sql></sqlb_project>
