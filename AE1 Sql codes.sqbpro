l_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1">PRAGMA foreign_keys = ON;
CREATE TABLE Clinic (
    clinic_id INTEGER PRIMARY KEY AUTOINCREMENT,

    clinic_name TEXT NOT NULL,

    -- Address stored as composite attributes
    street TEXT NOT NULL,
    city TEXT NOT NULL,
    postcode TEXT NOT NULL,

    neighbourhood TEXT NOT NULL,

    phone_number TEXT,
    email TEXT,

    opening_time TEXT NOT NULL,
    closing_time TEXT NOT NULL,

    -- 1 = active, 0 = inactive
    is_active INTEGER NOT NULL DEFAULT 1
        CHECK(is_active IN (0,1))
);

CREATE TABLE HealthcareWorker(
    worker_id INTEGER PRIMARY KEY AUTOINCREMENT,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    email TEXT,
    phone_number TEXT,
    role TEXT NOT NULL CHECK(role IN ('Doctor','Nurse','Pharmacist')),
    licence_number TEXT NOT NULL UNIQUE, --professional licence numbers must be unique
    --1 is active 0 is inactive
    is_active INTEGER NOT NULL DEFAULT 1 CHECK(is_active IN (0,1))
);

CREATE TABLE Patient (
    patient_id INTEGER PRIMARY KEY AUTOINCREMENT,
    primary_clinic_id INTEGER NOT NULL,
    first_name TEXT NOT NULL,
    last_name TEXT NOT NULL,
    date_of_birth TEXT NOT NULL,
    gender TEXT NOT NULL CHECK(gender IN ('Male','Female','Non-binary','Prefer not to say')),
    street TEXT NOT NULL,
    city TEXT NOT NULL,
    postcode TEXT NOT NULL,
    neighbourhood TEXT NOT NULL,
    email TEXT,
    phone_number TEXT,
    insurance_status TEXT NOT NULL CHECK(insurance_status IN ('Insured','Uninsured','Not Disclosed')),
    insurance_provider TEXT,
    registration_date TEXT NOT NULL,
    emergency_contact_name TEXT,
    emergency_contact_number TEXT,
    FOREIGN KEY (primary_clinic_id) REFERENCES Clinic(clinic_id)
);

CREATE TABLE ClinicWorker (
    worker_id INTEGER NOT NULL,
    clinic_id INTEGER NOT NULL,
    start_date TEXT NOT NULL,
    end_date TEXT,
    is_primary_clinic INTEGER NOT NULL DEFAULT 0 CHECK(is_primary_clinic IN (0,1)),
    -- composite primary key: one worker can be assigned to many clinics
    PRIMARY KEY (worker_id, clinic_id),
    FOREIGN KEY (worker_id) REFERENCES HealthcareWorker(worker_id),
    FOREIGN KEY (clinic_id) REFERENCES Clinic(clinic_id)
);

CREATE TABLE Vaccine (
    vaccine_id INTEGER PRIMARY KEY AUTOINCREMENT,
    vaccine_name TEXT NOT NULL,
    manufacturer TEXT NOT NULL,
    brand_name TEXT, -- commercial product name e.g. Comirnaty, Spikevax
    dose_count_required INTEGER NOT NULL CHECK(dose_count_required &gt;= 1),
    dose_interval_days INTEGER, -- NULL for single-dose vaccines
    dose_ml REAL NOT NULL CHECK(dose_ml &gt; 0),
    -- temperature stored as range not fixed value (resolves R3 ambiguity)
    storage_temp_min REAL NOT NULL,
    storage_temp_max REAL NOT NULL,
    -- shelf_life is general; actual expiry tracked per batch in VaccineBatch
    shelf_life_days INTEGER NOT NULL CHECK(shelf_life_days &gt; 0),
    is_active INTEGER NOT NULL DEFAULT 1 CHECK(is_active IN (0,1)) -- 1=active, 0=discontinued
);

CREATE TABLE VaccineBatch (
    batch_id INTEGER PRIMARY KEY AUTOINCREMENT,
    vaccine_id INTEGER NOT NULL, -- links to vaccine type
    clinic_id INTEGER NOT NULL, -- clinic holding this physical stock
    batch_number TEXT NOT NULL UNIQUE,
    manufacture_date TEXT NOT NULL,
    expiry_date TEXT NOT NULL, -- tracked per batch, not per vaccine type
    quantity_received INTEGER NOT NULL CHECK(quantity_received &gt; 0),
    quantity_remaining INTEGER NOT NULL CHECK(quantity_remaining &gt;= 0),
    received_date TEXT NOT NULL,
    storage_location TEXT, -- e.g. Fridge 2, Shelf B
    FOREIGN KEY (vaccine_id) REFERENCES Vaccine(vaccine_id),
    FOREIGN KEY (clinic_id) REFERENCES Clinic(clinic_id),
    -- ensures remaining stock never exceeds what was received
    CHECK (quantity_remaining &lt;= quantity_received)
);

CREATE TABLE Appointment (
    appointment_id INTEGER PRIMARY KEY AUTOINCREMENT,
    patient_id INTEGER NOT NULL,
    clinic_id INTEGER NOT NULL,
    vaccine_id INTEGER NOT NULL,
    worker_id INTEGER NOT NULL,
    appointment_date TEXT NOT NULL,
    appointment_time TEXT NOT NULL,
    appointment_status TEXT NOT NULL DEFAULT 'Scheduled' 
	--restricts status to four valid values matching real clinical workflow
    CHECK(appointment_status IN ('Scheduled','Completed','Cancelled','No-show')),
    note TEXT, -- optional free-text notes
    FOREIGN KEY (patient_id) REFERENCES Patient(patient_id),
    FOREIGN KEY (clinic_id) REFERENCES Clinic(clinic_id),
    FOREIGN KEY (vaccine_id) REFERENCES Vaccine(vaccine_id),
    FOREIGN KEY (worker_id) REFERENCES HealthcareWorker(worker_id)
);

CREATE TABLE VaccinationRecord (
    record_id INTEGER PRIMARY KEY AUTOINCREMENT,
    patient_id INTEGER NOT NULL,
    vaccine_id INTEGER NOT NULL,
    batch_id INTEGER NOT NULL, -- tracks exact batch for safety/recall purposes
    worker_id INTEGER NOT NULL, -- healthcare worker who administered the dose
    clinic_id INTEGER NOT NULL, -- may differ from patient's primary clinic (walk-ins)
    appointment_id INTEGER, -- nullable: walk-ins have no prior appointment
    administered_date TEXT NOT NULL,
    administered_time TEXT NOT NULL,
    dose_number INTEGER NOT NULL DEFAULT 1 CHECK(dose_number &gt;= 1),
    site_of_injection TEXT CHECK(site_of_injection IN 
        ('Left arm','Right arm','Left thigh','Right thigh')),
    adverse_reaction TEXT,
    next_dose_due TEXT,
    FOREIGN KEY (patient_id) REFERENCES Patient(patient_id),
    FOREIGN KEY (vaccine_id) REFERENCES Vaccine(vaccine_id),
    FOREIGN KEY (batch_id) REFERENCES VaccineBatch(batch_id),
    FOREIGN KEY (worker_id) REFERENCES HealthcareWorker(worker_id),
    FOREIGN KEY (clinic_id) REFERENCES Clinic(clinic_id),
    FOREIGN KEY (appointment_id) REFERENCES Appointment(appointment_id)
);

CREATE TABLE ImmunizationReport (
    report_id INTEGER PRIMARY KEY AUTOINCREMENT,
    clinic_id INTEGER NOT NULL,
    report_date TEXT NOT NULL,
    reporting_period TEXT NOT NULL 
        CHECK(reporting_period IN ('Monthly','Quarterly','Annual')),
    total_vaccinations INTEGER NOT NULL DEFAULT 0,
    total_patients INTEGER NOT NULL DEFAULT 0,
    -- coverage = total_vaccinations / total_patients * 100
    coverage_percentage REAL CHECK(coverage_percentage BETWEEN 0 AND 100),
    generated_by INTEGER, -- FK to HealthcareWorker who triggered the report
    FOREIGN KEY (clinic_id) REFERENCES Clinic(clinic_id),
    FOREIGN KEY (generated_by) REFERENCES HealthcareWorker(worker_id)
);



